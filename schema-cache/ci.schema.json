{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mereb.dev/ci.schema.json",
  "title": "Mereb CI configuration",
  "type": "object",
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "preset": {
      "type": "string",
      "enum": ["node", "pnpm", "java-gradle"]
    },
    "recipe": {
      "type": "string",
      "enum": ["build", "package", "image", "service", "microfrontend", "terraform"]
    },
    "agent": {
      "type": "object",
      "properties": {
        "label": { "type": "string" },
        "docker": { "type": "string" }
      },
      "additionalProperties": false
    },
    "app": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "chart": { "type": "string" },
        "namespace": { "type": "string" },
        "registry": { "type": "string" }
      }
    },
    "build": {
      "type": "object",
      "properties": {
        "preset": { "$ref": "#/properties/preset" },
        "stages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "verb": { "type": "string" },
              "sh": { "type": "string" },
              "env": { "type": "object", "additionalProperties": { "type": "string" } }
            },
            "oneOf": [
              { "required": ["verb"] },
              { "required": ["sh"] }
            ]
          }
        },
        "pnpm": { "$ref": "#/definitions/pnpmPreset" }
      },
      "additionalProperties": true
    },
    "matrix": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "image": {
      "oneOf": [
        { "type": "boolean" },
        {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "context": { "type": "string" },
            "dockerfile": { "type": "string" },
            "sbom": { "$ref": "#/definitions/sbom" },
            "scan": { "$ref": "#/definitions/scan" },
            "signing": { "$ref": "#/definitions/signing" },
            "platforms": {
              "type": "array",
              "items": { "type": "string" }
            },
            "push": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "when": { "type": "string" },
                "registry": { "type": "string" },
                "credentials": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "usernameEnv": { "type": "string" },
                    "passwordEnv": { "type": "string" }
                  },
                  "required": ["id"],
                  "additionalProperties": false
                }
              },
              "additionalProperties": true
            }
          },
          "required": ["repository"]
        }
      ]
    },
    "deploy": { "$ref": "#/definitions/environments" },
    "terraform": {
      "type": "object",
      "properties": {
        "path": { "type": "string" },
        "autoInstall": { "type": "boolean" },
        "version": { "type": "string" },
        "pluginCacheDir": { "type": "string" },
        "environments": { "$ref": "#/definitions/terraformEnvironments" }
      },
      "additionalProperties": true
    },
    "microfrontend": { "$ref": "#/definitions/microfrontend" },
    "release": {
      "type": "object",
      "properties": {
        "autoTag": { "$ref": "#/definitions/autoTag" },
        "github": { "$ref": "#/definitions/githubRelease" }
      }
    }
  },
  "required": ["version"],
  "additionalProperties": true,
  "definitions": {
    "pnpmPreset": {
      "type": "object",
      "properties": {
        "packageDir": { "type": "string" },
        "packageName": { "type": "string" },
        "lockfile": { "type": "string" },
        "tasks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "name": { "type": "string" },
              "command": { "type": "string" }
            },
            "required": ["type"]
          }
        }
      },
      "additionalProperties": true
    },
    "helmValue": {
      "oneOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "boolean" },
        { "type": "null" },
        {
          "type": "array",
          "items": { "$ref": "#/definitions/helmValue" }
        },
        {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/helmValue" }
        }
      ]
    },
    "helmValueObject": {
      "type": "object",
      "additionalProperties": { "$ref": "#/definitions/helmValue" }
    },
    "generatedValues": {
      "type": "object",
      "properties": {
        "profile": {
          "type": "string",
          "enum": ["outboxWorker"]
        },
        "overlay": { "$ref": "#/definitions/helmValueObject" }
      },
      "required": ["profile"],
      "additionalProperties": false
    },
    "generatedBaseExtraEnv": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "value": { "type": "string" },
        "fromPlatformIdentityConfigKey": { "type": "string" },
        "fromPlatformIdentitySecretKey": { "type": "string" },
        "optional": { "type": "boolean" }
      },
      "required": ["name"],
      "additionalProperties": false,
      "oneOf": [
        { "required": ["value"] },
        { "required": ["fromPlatformIdentityConfigKey"] },
        { "required": ["fromPlatformIdentitySecretKey"] }
      ]
    },
    "generatedBaseApiServiceInputs": {
      "type": "object",
      "properties": {
        "serviceName": { "type": "string" },
        "containerPort": { "type": "integer" },
        "routePrefix": { "type": "string" },
        "configMapName": { "type": "string" },
        "secretName": { "type": "string" },
        "tlsSecretName": { "type": "string" },
        "secretTemplates": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "extraEnv": {
          "type": "array",
          "items": { "$ref": "#/definitions/generatedBaseExtraEnv" }
        }
      },
      "required": [
        "serviceName",
        "containerPort",
        "routePrefix",
        "configMapName",
        "secretName",
        "tlsSecretName",
        "secretTemplates"
      ],
      "additionalProperties": false
    },
    "generatedBaseApiServiceInputsPartial": {
      "type": "object",
      "properties": {
        "serviceName": { "type": "string" },
        "containerPort": { "type": "integer" },
        "routePrefix": { "type": "string" },
        "configMapName": { "type": "string" },
        "secretName": { "type": "string" },
        "tlsSecretName": { "type": "string" },
        "secretTemplates": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "extraEnv": {
          "type": "array",
          "items": { "$ref": "#/definitions/generatedBaseExtraEnv" }
        }
      },
      "additionalProperties": false
    },
    "generatedBaseValues": {
      "type": "object",
      "properties": {
        "profile": {
          "type": "string",
          "enum": ["apiService"]
        },
        "inputs": { "$ref": "#/definitions/generatedBaseApiServiceInputsPartial" }
      },
      "minProperties": 1,
      "additionalProperties": false
    },
    "generatedBaseDefaults": {
      "type": "object",
      "properties": {
        "profile": {
          "type": "string",
          "enum": ["apiService"]
        },
        "inputs": { "$ref": "#/definitions/generatedBaseApiServiceInputsPartial" }
      },
      "required": ["profile", "inputs"],
      "additionalProperties": false
    },
    "deployDefaults": {
      "type": "object",
      "properties": {
        "chart": { "type": "string" },
        "repo": { "type": "string" },
        "repoCredentialId": { "type": "string" },
        "repoCredential": { "type": "string" },
        "repoCredentials": { "$ref": "#/definitions/repoCredentials" },
        "repoUsername": { "type": "string" },
        "repoPassword": { "type": "string" },
        "wait": { "type": "boolean" },
        "atomic": { "type": "boolean" },
        "timeout": { "type": "string" },
        "rolloutTimeout": { "type": "string" }
      },
      "additionalProperties": false
    },
    "environments": {
      "type": "object",
      "properties": {
        "order": {
          "type": "array",
          "items": { "type": "string" }
        },
        "defaults": { "$ref": "#/definitions/deployDefaults" },
        "generatedBaseDefaults": { "$ref": "#/definitions/generatedBaseDefaults" }
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "extends": { "type": "string" },
          "chart": { "type": "string" },
          "namespace": { "type": "string" },
          "repo": { "type": "string" },
          "repoCredentials": { "$ref": "#/definitions/repoCredentials" },
          "when": { "type": "string" },
          "values": {
            "type": "array",
            "items": { "type": "string" }
          },
          "valuesFiles": {
            "type": "array",
            "items": { "type": "string" }
          },
          "generatedBaseValues": { "$ref": "#/definitions/generatedBaseValues" },
          "generatedValues": { "$ref": "#/definitions/generatedValues" },
          "set": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "setString": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "setFile": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "approval": { "$ref": "#/definitions/approval" },
          "autoPromote": { "type": "boolean" },
          "kubeContext": { "type": "string" },
          "kubeconfig": { "type": "string" },
          "repoUsername": { "type": "string" },
          "repoPassword": { "type": "string" },
          "wait": { "type": "boolean" },
          "atomic": { "type": "boolean" },
          "timeout": { "type": "string" },
          "smoke": {
            "oneOf": [
              { "type": "boolean", "enum": [false] },
              {
                "type": "object",
                "properties": {
                  "url": { "type": "string", "format": "uri" },
                  "script": { "type": "string" }
                }
              }
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "terraformEnvironments": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "displayName": { "type": "string" },
          "when": { "type": "string" },
          "prePlan": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "array",
                "items": { "type": "string" }
              }
            ]
          },
          "lock": { "$ref": "#/definitions/terraformLock" },
          "verify": { "$ref": "#/definitions/terraformVerify" },
          "vars": {
            "type": "object",
            "additionalProperties": { "type": ["string", "number", "boolean"] }
          }
        },
        "additionalProperties": true
      }
    },
    "terraformVerify": {
      "type": "object",
      "properties": {
        "timeout": { "type": "string" },
        "resources": {
          "type": "array",
          "items": { "$ref": "#/definitions/terraformVerifyResource" }
        }
      },
      "additionalProperties": true
    },
    "terraformLock": {
      "type": "object",
      "properties": {
        "resource": { "type": "string" }
      },
      "required": ["resource"],
      "additionalProperties": true
    },
    "terraformVerifyResource": {
      "type": "object",
      "properties": {
        "kind": { "type": "string" },
        "name": { "type": "string" },
        "selector": { "type": "string" },
        "namespace": { "type": "string" },
        "optional": { "type": "boolean" },
        "wait": {
          "type": "string",
          "enum": ["exists", "ready", "available", "complete"]
        },
        "timeout": { "type": "string" }
      },
      "required": ["kind"],
      "additionalProperties": true
    },
    "credential": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "env": { "type": "string" },
        "usernameEnv": { "type": "string" },
        "passwordEnv": { "type": "string" }
      },
      "required": ["id"],
      "additionalProperties": true
    },
    "microfrontend": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "name": { "type": "string" },
        "manifestEntry": { "type": "string" },
        "manifestFlag": { "type": "string" },
        "distDir": { "type": "string" },
        "manifestScript": { "type": "string" },
        "checkScript": { "type": "string" },
        "nodeVersion": { "type": "string" },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "order": {
          "type": "array",
          "items": { "type": "string" }
        },
        "aws": {
          "type": "object",
          "properties": {
            "endpoint": { "type": "string" },
            "region": { "type": "string" },
            "forcePathStyle": { "type": "boolean" },
            "credential": { "$ref": "#/definitions/credential" },
            "credentials": {
              "type": "array",
              "items": { "$ref": "#/definitions/credential" }
            }
          },
          "additionalProperties": true
        },
        "environments": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "displayName": { "type": "string" },
              "bucket": { "type": "string" },
              "publicBase": { "type": "string" },
              "when": { "type": "string" },
              "env": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              },
              "credentials": {
                "type": "array",
                "items": { "$ref": "#/definitions/credential" }
              },
              "approval": { "$ref": "#/definitions/approval" },
              "clearBeforeSync": { "type": "boolean" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "autoTag": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "when": { "type": "string" },
        "bump": { "type": "string", "enum": ["major", "minor", "patch"] },
        "credential": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "type": { "type": "string", "enum": ["string", "usernamePassword"] }
          }
        }
      },
      "additionalProperties": true
    },
    "githubRelease": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "when": { "type": "string" },
        "credential": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "type": { "type": "string", "enum": ["string", "usernamePassword"] }
          }
        }
      },
      "additionalProperties": true
    },
    "sbom": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "format": { "type": "string" },
        "output": { "type": "string" }
      },
      "additionalProperties": true
    },
    "scan": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "failOn": { "type": "string" },
        "flags": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "signing": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "when": { "type": "string" },
        "key": { "type": "string" },
        "keyless": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "repoCredentials": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "usernameEnv": { "type": "string" },
        "passwordEnv": { "type": "string" }
      },
      "required": ["id"],
      "additionalProperties": false
    },
    "approval": {
      "type": "object",
      "properties": {
        "message": { "type": "string" },
        "before": { "type": "boolean" },
        "ok": { "type": "string" },
        "submitter": { "type": ["string", "array"] }
      },
      "additionalProperties": true
    }
  }
}
