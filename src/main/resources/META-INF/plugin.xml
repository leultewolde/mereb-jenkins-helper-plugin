<idea-plugin>
    <id>org.mereb.jenkins.helper</id>
    <name>Mereb Jenkins Helper</name>
    <vendor>Mereb</vendor>
    <description><![CDATA[
    Interactive editor support for Mereb Jenkins configuration files. Adds <code>.mjc</code>
    file handling, schema validation, field-level inspections, one-click fixes, recipe-aware
    config generation, migration help, a pipeline preview tool window, Jenkins sign-in with
    live read-only project data, and upstream schema checks.
  ]]></description>
    <resource-bundle>messages.MerebJenkinsBundle</resource-bundle>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.json</depends>
    <depends>org.jetbrains.plugins.yaml</depends>

    <extensions defaultExtensionNs="JavaScript.JsonSchema">
        <ProviderFactory implementation="org.mereb.jenkins.mjc.MerebJenkinsSchemaProviderFactory"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup
                id="Mereb Jenkins"
                key="notification.group.mereb.jenkins"
                displayType="BALLOON"
                isLogByDefault="true"/>
        <postStartupActivity implementation="org.mereb.jenkins.mjc.MerebJenkinsOnboardingActivity"/>
        <applicationConfigurable
                parentId="tools"
                instance="org.mereb.jenkins.mjc.MerebJenkinsSettingsConfigurable"
                id="org.mereb.jenkins.helper.settings"
                key="settings.mereb.jenkins.helper.display.name"
                bundle="messages.MerebJenkinsBundle"/>
        <fileType
                name="Mereb Jenkins Configuration"
                implementationClass="org.mereb.jenkins.mjc.MerebJenkinsConfigurationFileType"
                fieldName="INSTANCE"
                language="yaml"
                extensions="mjc"/>
        <lang.inspectionSuppressor
                language="yaml"
                implementationClass="org.mereb.jenkins.mjc.MerebJenkinsInspectionSuppressor"/>
        <lang.syntaxHighlighterFactory
                language="yaml"
                implementationClass="org.mereb.jenkins.mjc.MerebJenkinsSyntaxHighlighterFactory"/>
        <colorSettingsPage implementation="org.mereb.jenkins.mjc.MerebJenkinsColorSettingsPage"/>
        <completion.contributor
                language="yaml"
                implementationClass="org.mereb.jenkins.mjc.MerebJenkinsCompletionContributor"/>
        <typedHandler implementation="org.mereb.jenkins.mjc.MerebJenkinsCompletionTypedHandler"/>
        <lang.documentationProvider
                language="yaml"
                implementationClass="org.mereb.jenkins.mjc.MerebJenkinsDocumentationProvider"/>
        <codeInsight.inlayProvider
                language="yaml"
                id="MerebJenkinsBlockMetadata"
                implementationClass="org.mereb.jenkins.mjc.MerebJenkinsBlockInlayHintsProvider"/>
        <toolWindow id="Mereb Jenkins"
                    anchor="right"
                    icon="/icons/mereb-toolwindow.svg"
                    factoryClass="org.mereb.jenkins.mjc.MerebJenkinsToolWindowFactory"
                    canCloseContents="false"/>
        <annotator
                language="yaml"
                implementationClass="org.mereb.jenkins.mjc.MerebJenkinsRelationAnnotator"/>
        <annotator
                language="yaml"
                implementationClass="org.mereb.jenkins.mjc.MerebJenkinsScalarAnnotator"/>
        <codeInsight.lineMarkerProvider
                language="yaml"
                implementationClass="org.mereb.jenkins.mjc.MerebJenkinsLineMarkerProvider"/>
        <localInspection
                language="yaml"
                shortName="LegacyMerebJenkinsConfigFilename"
                key="inspection.legacy.filename.display.name"
                groupKey="inspection.group.name"
                enabledByDefault="true"
                level="WEAK WARNING"
                implementationClass="org.mereb.jenkins.mjc.LegacyMerebJenkinsConfigInspection"/>
        <localInspection
                language="yaml"
                shortName="MerebJenkinsConfigSemantics"
                key="inspection.config.semantics.display.name"
                groupKey="inspection.group.name"
                enabledByDefault="true"
                level="WARNING"
                implementationClass="org.mereb.jenkins.mjc.MerebJenkinsConfigSemanticInspection"/>
    </extensions>

    <actions>
        <action id="org.mereb.jenkins.helper.NewConfig"
                class="org.mereb.jenkins.mjc.MerebJenkinsNewConfigAction">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action id="org.mereb.jenkins.helper.MigrateConfig"
                class="org.mereb.jenkins.mjc.MerebJenkinsMigrationAssistantAction">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action id="org.mereb.jenkins.helper.HowTo"
                class="org.mereb.jenkins.mjc.MerebJenkinsHowToAction">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <add-to-group group-id="HelpMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
