<idea-plugin>
    <id>org.mereb.jenkins.helper</id>
    <name>Mereb Jenkins Helper</name>
    <vendor>Mereb</vendor>
    <description><![CDATA[
    Interactive editor support for Mereb Jenkins configuration files. Adds <code>.mjc</code>
    file handling, schema validation, field-level inspections, one-click fixes, recipe-aware
    config generation, migration help, a pipeline preview tool window, Jenkins sign-in with
    live read-only project data, and upstream schema checks.
  ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.json</depends>
    <depends>org.jetbrains.plugins.yaml</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="Mereb Jenkins" displayType="BALLOON" isLogByDefault="true"/>
        <postStartupActivity implementation="org.mereb.intellij.mjc.MerebJenkinsOnboardingActivity"/>
        <applicationConfigurable
                parentId="tools"
                instance="org.mereb.intellij.mjc.MerebJenkinsSettingsConfigurable"
                id="org.mereb.jenkins.helper.settings"
                displayName="Mereb Jenkins Helper"/>
        <fileType
                name="Mereb Jenkins Configuration"
                implementationClass="org.mereb.intellij.mjc.MerebJenkinsConfigurationFileType"
                fieldName="INSTANCE"
                language="yaml"
                extensions="mjc"/>
        <jsonSchemaProviderFactory implementation="org.mereb.intellij.mjc.MerebJenkinsSchemaProviderFactory"/>
        <lang.inspectionSuppressor
                language="yaml"
                implementationClass="org.mereb.intellij.mjc.MerebJenkinsInspectionSuppressor"/>
        <lang.syntaxHighlighterFactory
                language="yaml"
                implementationClass="org.mereb.intellij.mjc.MerebJenkinsSyntaxHighlighterFactory"/>
        <colorSettingsPage implementation="org.mereb.intellij.mjc.MerebJenkinsColorSettingsPage"/>
        <completion.contributor
                language="yaml"
                implementationClass="org.mereb.intellij.mjc.MerebJenkinsCompletionContributor"/>
        <typedHandler implementation="org.mereb.intellij.mjc.MerebJenkinsCompletionTypedHandler"/>
        <lang.documentationProvider
                language="yaml"
                implementationClass="org.mereb.intellij.mjc.MerebJenkinsDocumentationProvider"/>
        <codeInsight.inlayProvider
                language="yaml"
                id="MerebJenkinsBlockMetadata"
                implementationClass="org.mereb.intellij.mjc.MerebJenkinsBlockInlayHintsProvider"/>
        <toolWindow id="Mereb Jenkins"
                    anchor="right"
                    icon="/icons/mereb-toolwindow.svg"
                    factoryClass="org.mereb.intellij.mjc.MerebJenkinsToolWindowFactory"
                    canCloseContents="false"/>
        <annotator
                language="yaml"
                implementationClass="org.mereb.intellij.mjc.MerebJenkinsRelationAnnotator"/>
        <annotator
                language="yaml"
                implementationClass="org.mereb.intellij.mjc.MerebJenkinsScalarAnnotator"/>
        <localInspection
                language="yaml"
                shortName="LegacyMerebJenkinsConfigFilename"
                displayName="Legacy Mereb Jenkins config filename"
                groupName="Mereb Jenkins"
                enabledByDefault="true"
                level="WEAK WARNING"
                implementationClass="org.mereb.intellij.mjc.LegacyMerebJenkinsConfigInspection"/>
        <localInspection
                language="yaml"
                shortName="MerebJenkinsConfigSemantics"
                displayName="Mereb Jenkins config semantics"
                groupName="Mereb Jenkins"
                enabledByDefault="true"
                level="WARNING"
                implementationClass="org.mereb.intellij.mjc.MerebJenkinsConfigSemanticInspection"/>
    </extensions>

    <actions>
        <action id="org.mereb.jenkins.helper.NewConfig"
                class="org.mereb.intellij.mjc.MerebJenkinsNewConfigAction"
                text="New Mereb Jenkins Config"
                description="Create a recipe-aware Mereb Jenkins config">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action id="org.mereb.jenkins.helper.MigrateConfig"
                class="org.mereb.intellij.mjc.MerebJenkinsMigrationAssistantAction"
                text="Migrate Mereb Jenkins Config"
                description="Preview and apply a conservative migration to .ci/ci.mjc">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action id="org.mereb.jenkins.helper.HowTo"
                class="org.mereb.intellij.mjc.MerebJenkinsHowToAction"
                text="How To Use Mereb Jenkins Helper"
                description="Show the built-in guide for the Mereb Jenkins plugin">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <add-to-group group-id="HelpMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
